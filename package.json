{
  "name": "launchd-icon-helper",
  "version": "1.0.0",
  "description": "A macOS tray app for managing launchd services with a friendly UI",
  "main": "main/main.js",
  "scripts": {
    "dev": "vite build && electron .",
    "build:renderer": "vite build",
    "start": "electron .",
    "build": "vite build && electron-builder",
    "install-autostart": "node scripts/install-autostart.js",
    "remove-autostart": "node scripts/remove-autostart.js"
  },
  "author": "Ben Greenberg",
  "license": "MIT",
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "vite": "^6.0.0"
  },
  "dependencies": {
    "plist": "^3.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "build": {
    "appId": "com.bengreenberg.launchd-icon-helper",
    "productName": "Launchd Helper",
    "mac": {
      "category": "public.app-category.utilities",
      "icon": "assets/icon.png",
      "target": "dmg"
    },
    "files": [
      "main/**/*",
      "dist/**/*",
      "assets/**/*"
    ]
  }
}
